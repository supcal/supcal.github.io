{% if site.bib_search %}
  <script src="{{ '/assets/js/bibsearch.js' | relative_url | bust_file_cache }}" type="module"></script>

  <div class="pub-filter-bar">
    <!-- 搜索框 -->
    <input type="text" id="bibsearch" spellcheck="false" autocomplete="off" class="search bibsearch-form-input" placeholder="搜索标题、作者、关键词...">

    <!-- 类型筛选 -->
    <select id="type-filter" class="pub-filter-select">
      <option value="all">全部类型</option>
      <option value="article">期刊论文 (Journal)</option>
      <option value="inproceedings">会议论文 (Conference)</option>
    </select>

    <!-- 年份筛选 -->
    <div class="year-filters" id="year-filters">
      <button class="year-btn active" data-year="all">全部年份</button>
    </div>
  </div>

  <script>
    (function() {
      function initFilters() {
        var groups = document.querySelectorAll('.publications h2');
        var container = document.getElementById('year-filters');
        var typeSelect = document.getElementById('type-filter');
        if (!container || !groups.length) return;

        var years = [];
        groups.forEach(function(h) {
          var m = h.textContent.trim().match(/\d{4}/);
          if (m && years.indexOf(m[0]) === -1) years.push(m[0]);
        });
        years.sort(function(a,b){return b-a});
        years.forEach(function(y) {
          var btn = document.createElement('button');
          btn.className = 'year-btn';
          btn.dataset.year = y;
          btn.textContent = y;
          container.appendChild(btn);
        });

        function applyFilters() {
          var selectedYear = container.querySelector('.year-btn.active');
          var year = selectedYear ? selectedYear.dataset.year : 'all';
          var type = typeSelect.value;
          var searchVal = (document.getElementById('bibsearch').value || '').toLowerCase();

          var allItems = document.querySelectorAll('.publications .bibliography > li');
          allItems.forEach(function(li) {
            var show = true;
            // Type filter
            if (type !== 'all') {
              var periodical = li.querySelector('.periodical');
              if (periodical) {
                var text = periodical.textContent.toLowerCase();
                if (type === 'article' && text.includes('proceeding')) show = false;
                if (type === 'inproceedings' && !text.includes('proceeding') && !text.includes('conference') && !text.includes('symposium') && !text.includes('workshop') && !text.includes('icassp') && !text.includes('icip')) show = false;
              }
            }
            // Year filter - show/hide year group
            if (year !== 'all') {
              var h2 = li.closest('.publications').querySelector('h2');
              // Better: find parent year heading
              var pubDiv = li.closest('.publications');
              var allH2s = pubDiv.querySelectorAll('h2');
              var parentYear = '';
              allH2s.forEach(function(h) {
                if (h.compareDocumentPosition(li) & Node.DOCUMENT_POSITION_FOLLOWING) {
                  if (!parentYear || (h.compareDocumentPosition(allH2s[Array.from(allH2s).indexOf(h)-1]) & Node.DOCUMENT_POSITION_PRECEDING)) {
                    // just use the h2 before this li
                  }
                }
              });
              // Simple approach: just use the year from abstract/periodical
              var periodical = li.querySelector('.periodical');
              if (periodical) {
                var yearMatch = periodical.textContent.match(/(\\d{4})/);
                if (!yearMatch || yearMatch[1] !== year) show = false;
              }
            }
            // Search filter (handled by bibsearch.js, but we also apply here)
            if (searchVal) {
              var text = li.textContent.toLowerCase();
              if (text.indexOf(searchVal) === -1) show = false;
            }
            li.style.display = show ? '' : 'none';
          });
        }

        // Year button click
        container.addEventListener('click', function(e) {
          if (e.target.tagName !== 'BUTTON') return;
          container.querySelectorAll('.year-btn').forEach(function(b){b.classList.remove('active')});
          e.target.classList.add('active');
          applyFilters();
        });

        // Type select change
        typeSelect.addEventListener('change', applyFilters);

        // Intercept bibsearch input
        var searchInput = document.getElementById('bibsearch');
        if (searchInput) {
          searchInput.addEventListener('input', applyFilters);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFilters);
      } else {
        initFilters();
      }
    })();
  </script>
{% endif %}
